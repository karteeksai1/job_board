# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration (PostgreSQL)
# For Neon/Supabase: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# For local Postgres: postgresql://USER:PASSWORD@localhost:5432/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobboard?schema=public"

# JWT configuration
JWT_SECRET="your-super-secret-access-token-key-change-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-token-key-change-this"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Client configuration (Vite prefix required for frontend ingestion)
VITE_API_URL="http://localhost:5000"
